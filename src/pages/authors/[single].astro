---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { Image } from "astro:assets";

import config from "@/config/config.json"; 
import { sortByDate } from "@/lib/utils/sortFunctions";
import { humanize, slugify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";
import AuthorSingle from "@/partials/AuthorSingle.astro";

export async function getStaticPaths() {
  const authors = await getSinglePage("authors");

  // ස්වයංක්‍රීය නිවැරදි කිරීම: Authors ලැයිස්තුව හිස් නම් බිල්ඩ් එක Fail වීම වළක්වයි
  if (!authors || authors.length === 0) return [];

  const paths = authors.map((author) => ({
    params: {
      single: author.id,
    },
    props: { author },
  }));
  return paths;
}

const { author } = Astro.props;

// 1. දත්ත හිස් නම් සිදුවන සයිට් ක්‍රෑෂ් (Crash) වැළැක්වීම (Auto-Fix)
if (!author || !author.data) {
  return Astro.redirect("/404");
}

const { title, meta_title, description, image } = author.data;
const authorTitle = title || "";

// Author Posts ආරක්ෂිතව ලබා ගැනීම සහ Filter කිරීම
const posts = await getSinglePage("posts");
const sortPostsByDate: CollectionEntry<"posts">[] = sortByDate(posts || []);

const currentPosts = sortPostsByDate.filter((post) => {
  if (!post?.data?.authors || !Array.isArray(post.data.authors)) return false;
  
  return post.data.authors
    .map((authorName) => slugify(authorName || ""))
    .includes(slugify(authorTitle));
});

// 📈 SEO ප්‍රශස්තකරණය: Canonical URL එක Trailing Slashes බග් එක නැතිව පිරිසිදුව සැකසීම
const base_url = (config?.site?.base_url || "").replace(/\/$/, ""); 
const canonicalUrl = `${base_url}/authors/${author.id}`;

// 🚀 GOOGLE SEO RICH SNIPPETS: ලේඛකයා සඳහා වන Schema JSON-LD දත්ත ව්‍යුහය (ProfilePage -> Person)
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": authorTitle,
    "description": description || "",
    "image": image ? (image.startsWith("http") ? image : `${base_url}${image}`) : undefined,
    "url": canonicalUrl,
    "jobTitle": "Content Creator" // Google බොට් එකට ලේඛකයාගේ වෘත්තිය හඳුනාගැනීමට (SEO Booster)
  }
};
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  {/* ලේඛකයාගේ පෞද්ගලික විස්තර කොටස */}
  <AuthorSingle author={author} />

  {
    currentPosts && currentPosts.length > 0 && (
      // කළු පසුබිමට ගැළපෙන පරිදි පසුබිම සහ අකුරු වර්ණ වෙනස් කිරීම (Dark Mode Optimized)
      <section class="section pt-0 bg-slate-900 text-slate-100 min-h-[50vh] selection:bg-amber-500/30 selection:text-amber-200">
        <div class="container mx-auto px-4">
          
          {/* Recent Posts මාතෘකාව කළු පසුබිමේ රන්වන් පැහැයෙන් ඉස්මතු කිරීම */}
          <h2 class="mb-12 text-center h3 text-white font-bold tracking-tight">
            Recent Posts by <span class="text-amber-400 drop-shadow-[0_2px_8px_rgba(251,191,36,0.2)]">{authorTitle}</span>
          </h2>
          
          <div class="flex flex-wrap -mx-4 gy-4 justify-center md:justify-start">
            {currentPosts.map((post, index) => (
              <div class="w-full sm:w-1/2 lg:w-1/3 p-4">
                <div class="bg-slate-800/40 border border-slate-800/60 rounded-2xl overflow-hidden p-3 h-full transition duration-300 hover:border-amber-500/30 hover:bg-slate-800/70 backdrop-blur-sm group flex flex-col justify-between">
                  
                  <div>
                    {/* Post Image */}
                    {post?.data?.image && (
                      <a
                        href={`/blog/${post.id}/`}
                        class="rounded-xl block overflow-hidden bg-slate-900"
                      >
                        <Image
                          class="group-hover:scale-[1.03] transition duration-300 w-full object-cover h-[200px]"
                          src={post.data.image}
                          alt={post.data.title || "Post Image"}
                          width={445}
                          height={230}
                          loading={index < 3 ? "eager" : "lazy"} // පළමු කාඩ්පත් 3 සඳහා මුලින්ම ලෝඩ් වීම (Page Speed Fix)
                          format="webp" // පින්තූරවල ප්‍රමාණය අඩු කර වේගය වැඩි කිරීමට (SEO Advantage)
                        />
                      </a>
                    )}
                    
                    {/* Meta Data (Date & Categories) */}
                    <ul class="mt-4 text-slate-400 flex flex-wrap items-center text-sm gap-y-2">
                      {post?.data?.date && (
                        <li class="mr-4 flex items-center font-medium text-slate-300">
                          <BiCalendarEdit className="mr-1 h-[16px] w-[16px] text-amber-500/80" />
                          {dateFormat(post.data.date).toString()} {/* [object Object] බග් එක මඟහැරීමට .toString() ආරක්ෂාව */}
                        </li>
                      )}
                      
                      {post?.data?.categories && Array.isArray(post.data.categories) && (
                        <li class="flex items-center">
                          <BiCategoryAlt className="mr-1 h-[16px] w-[16px] text-amber-500/80" />
                          <div class="flex flex-wrap gap-1">
                            {post.data.categories.map((category, i: number) => (
                              <a
                                href={`/categories/${slugify(category || "")}/`}
                                class="text-amber-400/90 hover:text-amber-300 font-medium transition duration-200"
                              >
                                {humanize(category || "")}
                                {i !== post.data.categories!.length - 1 && <span class="text-slate-500 ml-1">,</span>}
                              </a>
                            ))}
                          </div>
                        </li>
                      )}
                    </ul>
                    
                    {/* Post Title */}
                    <h3 class="h5 mt-4 leading-snug">
                      <a
                        href={`/blog/${post.id}/`}
                        class="block text-white hover:text-amber-400 font-bold transition duration-300"
                      >
                        {post?.data?.title || "Untitled Post"}
                      </a>
                    </h3>
                  </div>
                  
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }
</Base>
