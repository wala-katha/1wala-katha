---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import { BiSpreadsheet, BiEnvelope, BiPhoneCall, BiXCircle, BiCheckCircle } from "react-icons/bi"; // ⚡ සාර්ථක පණිවිඩය සඳහා BiCheckCircle එක් කළා

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;

if (!entry || !entry.data) {
  return Astro.redirect("/404");
}

const { address, email, phone } = config.contactinfo;
const { title, description, meta_title, image } = entry.data;

const base_url = (config?.site?.base_url || "").replace(/\/$/, ""); 
const canonicalUrl = `${base_url}/contact`;

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": title || "Contact Us",
  "description": description || "අපේ වෙබ් අඩවිය සම්බන්ධ කර ගැනීමට අවශ්‍ය සියලුම තොරතුරු මෙතැනින් ලබා ගන්න.",
  "url": canonicalUrl,
  "mainEntity": {
    "@type": "Organization",
    "name": config?.site?.title || "Wala Katha",
    "url": base_url,
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": phone || "",
      "contactType": "customer service",
      "email": email || ""
    }
  }
};
---

<Base
  title={title}
  meta_title={meta_title}
  description={description || "අපේ වෙබ් අඩවිය සම්බන්ධ කර ගැනීමට අවශ්‍ය සියලුම තොරතුරු මෙතැනින් ලබා ගන්න."}
  image={image}
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <section class="section">
    <div class="container">
      <h1 set:html={markdownify(title)} class="h2 page-heading" />
      <div class="row md:gx-5 gy-5">
        <div class="sm:col-5 md:col-4">
          <p class="mb-8 text-2xl font-bold text-text dark:text-slate-100">Contact Info</p>
          <ul class="flex flex-col space-y-8">
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiSpreadsheet className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Address</p>
              </div>
              <p set:html={markdownify(address)} class="mt-2 leading-5 pl-8 text-text/80 dark:text-slate-300" />
            </li>
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiEnvelope className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Email</p>
              </div>
              <p set:html={markdownify(email)} class="mt-2 leading-5 pl-8 content text-text/80 dark:text-slate-300" />
            </li>
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiPhoneCall className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Phone</p>
              </div>
              <p set:html={markdownify(phone)} class="mt-2 leading-5 pl-8 text-text/80 dark:text-slate-300" />
            </li>
          </ul>
        </div>
        
        <div class="sm:col-7 md:col-8">
          {/* ⚡ SMART NOTICE BOX: පණිවිඩය සාර්ථකව ගිය විට පෙන්වන ලස්සන ස්තුති කිරීමේ කොටස */}
          <div id="form-success-alert" class="hidden mb-6 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/30 flex items-start text-emerald-400">
            <BiCheckCircle className="h-6 w-6 mr-3 flex-shrink-0 mt-0.5" />
            <div>
              <p class="font-bold text-lg">පණිවිඩය සාර්ථකව ලැබුණා!</p>
              <p class="text-sm opacity-90 mt-1">අප හා සම්බන්ධ වීම පිළිබඳව ස්තුතියි. ඔබගේ විමසීමට හැකි ඉක්මනින් පිළිතුරු සපයන්නෙමු.</p>
            </div>
          </div>

          {/* Form Action එක Formspree වෙතට කෙලින්ම සම්බන්ධ කළා */}
          <form
            id="smart-contact-form"
            class="contact-form row gy-3 justify-center"
            method="POST"
            action="https://formspree.io/f/xanygbbz"
          >
            {/* Name Input */}
            <div class="lg:col-6 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="name">
                Name <span class="text-red-600">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  class="form-input w-full rounded-lg bg-white dark:bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important;"
                  name="name"
                  type="text"
                  required
                />
                <button type="button" class="clear-btn absolute right-3 text-gray-400 hover:text-red-500 hidden transition-all">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            {/* Email Input */}
            <div class="lg:col-6 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="email">
                Email <span class="text-red-600">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  class="form-input w-full rounded-lg bg-white dark:bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important;"
                  name="email"
                  type="email"
                  required
                />
                <button type="button" class="clear-btn absolute right-3 text-gray-400 hover:text-red-500 hidden transition-all">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            {/* Subject Input */}
            <div class="col-12 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="subject">Subject</label>
              <div class="relative flex items-center">
                <input 
                  class="form-input w-full rounded-lg bg-white dark:bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10" 
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important;"
                  name="subject" 
                  type="text" 
                />
                <button type="button" class="clear-btn absolute right-3 text-gray-400 hover:text-red-500 hidden transition-all">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            {/* Message Input */}
            <div class="col-12 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="message">
                Message <span class="text-red-600">*</span>
              </label>
              <div class="relative">
                <textarea 
                  class="form-textarea w-full rounded-lg bg-white dark:bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10" 
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important;"
                  name="message" 
                  rows="4" 
                  required
                ></textarea>
                <button type="button" class="clear-btn absolute right-3 top-3 text-gray-400 hover:text-red-500 hidden transition-all">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            <div class="col-12">
              <button id="submit-btn" class="btn btn-primary mt-2 transition duration-300 hover:shadow-lg hover:shadow-primary/20 w-full sm:w-auto">
                Submit Now
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  {/* ⚡ SMART FUNCTIONALITY: AJAX Form Submit & Clear Buttons */}
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("smart-contact-form");
      const successAlert = document.getElementById("form-success-alert");
      const submitBtn = document.getElementById("submit-btn");
      const formContainers = document.querySelectorAll(".relative");

      // 1. Inputs ලියද්දී ❌ බටන් එක වැඩ කරවන කොටස
      formContainers.forEach(container => {
        const input = container.querySelector(".form-input, .form-textarea");
        const clearBtn = container.querySelector(".clear-btn");

        if (!input || !clearBtn) return;

        input.addEventListener("input", () => {
          if (input.value.length > 0) {
            clearBtn.classList.remove("hidden");
          } else {
            clearBtn.classList.add("hidden");
          }
        });

        clearBtn.addEventListener("click", () => {
          input.value = "";
          clearBtn.classList.add("hidden");
          input.focus();
        });
      });

      // 2. SMART AJAX SUBMIT: සයිට් එක Reload නොවී පණිවිඩය යැවීම සහ Notice එක පෙන්වීම
      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault(); // Default Page Reload එක නවත්වයි
          
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = "Sending...";
          }

          const data = new FormData(form);
          
          try {
            const response = await fetch(form.action, {
              method: form.method,
              body: data,
              headers: {
                'Accept': 'application/json'
              }
            });

            if (response.ok) {
              // සාර්ථක නම් Alert එක පෙන්වා Form එක Clear කරයි
              if (successAlert) {
                successAlert.classList.remove("hidden");
                successAlert.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
              form.reset();
              // සියලුම ❌ බටන් සඟවන්න
              document.querySelectorAll(".clear-btn").forEach(btn => btn.classList.add("hidden"));
            } else {
              alert("පණිවිඩය යැවීමේදී ගැටලුවක් ඇතිවිය. කරුණාකර නැවත උත්සාහ කරන්න.");
            }
          } catch (error) {
            alert("ජාල සම්බන්ධතා දෝෂයක්. කරුණාකර අන්තර්ජාලය පරීක්ෂා කරන්න.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = "Submit Now";
            }
          }
        });
      }
    });
  </script>
</Base>
