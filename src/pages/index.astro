---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import FeaturedSlider from "@/layouts/components/FeaturedSlider.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);

// 🎯 SEO උපරිම කිරීමට නිල URL එක සහ ප්‍රධාන තොරතුරු සකස් කිරීම
const base_url = (config?.site?.base_url || "").replace(/\/$/, "");
const canonicalUrl = base_url;

// 🚀 ADVANCED SEO: ගූගල් රොබෝලාට සයිට් එකේ ව්‍යුහය එක පාරින්ම වටහා දෙන නිල WebSite Schema එක
const homePageSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": config?.site?.title || "Wala Katha",
  "alternateName": ["සිංහල වල් කතා", "Sinhala Wal Katha", "Wela Katha"],
  "url": canonicalUrl,
  "description": "නවතම සිංහල වල් කතා සහ වැල කතා කියවන්න. Sinhala wal katha stories and high quality digital updates.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${base_url}/search?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<Base 
  title="සිංහල වල් කතා | Sinhala Wal Katha & Wela Katha Stories"
  description="නවතම සිංහල වල් කතා, වැල කතා සහ රසවත් කෙටි කතා එකතුවක් එකම තැනකින් කියවන්න. Daily updated Sinhala wal katha and wela stories."
  canonical={canonicalUrl}
>
  {/* JSON-LD ව්‍යුහාත්මක දත්ත මුලින්ම ඇතුළත් කිරීම */}
  <script type="application/ld+json" set:html={JSON.stringify(homePageSchema)} />

  {/* ⚡ TRUE DARK BACKGROUND FOR THE WHOLE PAGE (පෙනුම වෙනස් නොකර පසුබිම පමණක් කළු කරයි) */}
  <section class="section pt-4 min-h-screen bg-neutral-950 text-slate-100 dark:bg-neutral-950 dark:text-slate-100 selection:bg-primary selection:text-white">
    <div class="container">
      
      {/* 🚀 CRITICAL SEO FIX: සර්ච් එන්ජින් වලට පමණක් පෙනෙන, කියවීමට පහසු ප්‍රධාන H1 මාතෘකාව */}
      <h1 class="sr-only">සිංහල වල් කතා | Sinhala Wal Katha & Wela Katha Stories - නවතම කතා එකතුව</h1>

      {/* පෝස්ට් ලිස්ට් එකට ඉහළින් ඔටෝ මාරු වෙන පින්තූර කැට ඇනිමේෂන් ස්ලයිඩරය */}
      <FeaturedSlider posts={sortedPosts} />

      {/* ප්‍රධාන පෝස්ට් ලිස්ට් එක (ග්‍රිඩ් එක) */}
      <Posts posts={currentPosts} className="mb-16" />
      
      {/* පිටු මාරු කරන පටිය (Pagination) */}
      <Pagination currentPage={1} totalPages={totalPages} />
      
    </div>
  </section>
</Base>
