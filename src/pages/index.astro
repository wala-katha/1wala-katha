---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import FeaturedSlider from "@/layouts/components/FeaturedSlider.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);

// 🎯 SEO උපරිම කිරීමට නිල URL එක සහ ප්‍රධාන තොරතුරු සකස් කිරීම
const base_url = (config?.site?.base_url || "").replace(/\/$/, "");
const canonicalUrl = base_url;
const siteLogo = `${base_url}/images/logo.png`; 

// 🚀 ADVANCED SEO: නිල WebSite Schema එක (Search Action සහ Keywords සමඟ)
const homePageSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": config?.site?.title || "Wala Katha",
  "alternateName": [
    "සිංහල වල් කතා", 
    "Sinhala Wal Katha", 
    "Wela Katha", 
    "Wal Katha", 
    "Wala Katha Stories", 
    "Sinhala Wela Katha",
    "අලුත්ම වල් කතා"
  ],
  "url": canonicalUrl,
  "description": "අලුත්ම සහ රසවත්ම සිංහල වල් කතා සහ වැල කතා කියවන්න. Daily updated high quality Sinhala wal katha stories, wela katha and digital updates.",
  "image": siteLogo,
  "publisher": {
    "@type": "Organization",
    "name": config?.site?.title || "Wala Katha",
    "logo": {
      "@type": "ImageObject",
      "url": siteLogo
    }
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${base_url}/?search={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<Base 
  title="සිංහල වල් කතා | Sinhala Wal Katha & Wela Katha Stories"
  meta_title="සිංහල වල් කතා | Sinhala Wal Katha & Wela Katha Stories - WalaKatha"
  description="නවතම සිංහල වල් කතා, වැල කතා, අලුත්ම කෙටි කතා සහ රසවත් කතා එකතුවක් එකම තැනකින් කියවන්න. Daily updated Sinhala wal katha and wela stories collection."
  canonical={canonicalUrl}
>
  {/* JSON-LD ව්‍යුහාත්මක දත්ත */}
  <script type="application/ld+json" set:html={JSON.stringify(homePageSchema)} />

  {/* ⚡ PREMIUM ULTRA-DARK BACKGROUND & POPUP ENHANCEMENT */}
  <style is:inline>
    /* මුළු සයිට් එකම ලෝඩ් වෙද්දීම Flash නොවී කළු පසුබිම තබා ගැනීම */
    html, body {
      background-color: #050505 !important;
      color: #f8fafc !important; 
      scrollbar-color: #10b981 #050505; 
      font-display: swap;
    }
    
    /* 🧩 Post Cards වල මූලික හැඩය (දැනට තියෙන Layout එක වෙනස් නොවේ) */
    :global(.post-card), :global(.card), :global(.bg-body), :global(.bg-white) {
      background-color: #0b0c0e !important; /* වඩාත් ගැළපෙන Obsidian Black වර්ණය */
      border: 1px solid #161b22 !important;
      border-radius: 16px !important;
      will-change: transform, box-shadow;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), 
                  box-shadow 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), 
                  border-color 0.3s ease !important;
    }
    
    /* 🔥 3D POPUP EFFECT: පෝස්ට් කාඩ් මතින් යද්දී සුමටව ඉදිරියට නෙරා ඒම (Popup) සහ Emerald Neon Glow එකක් වැදීම */
    :global(.post-card:hover), :global(.card:hover) {
      background-color: #101216 !important;
      border-color: #10b981 !important; /* Glow එකට ගැළපෙන Border එක */
      transform: scale(1.03) translateY(-4px) !important; /* ත්‍රිමාණ ලෙස උඩට මතුවන Popup ස්ටයිල් එක */
      box-shadow: 0 20px 40px -15px rgba(16, 185, 129, 0.35), 
                  0 0 25px -5px rgba(16, 185, 129, 0.15) !important;
      z-index: 10;
    }
    
    /* අකුරු ඉස්මතු කිරීම සහ වර්ණ ගැළපීම */
    :global(.post-card-title), :global(.post-card h3), :global(.post-card h3 a), :global(.post-card a) {
      color: #ffffff !important;
      font-weight: 700 !important;
      transition: color 0.2s ease !important;
    }
    
    /* Hover වෙද්දී Title එක Emerald වර්ණයෙන් දිලිසීම */
    :global(.post-card:hover h3 a), :global(.post-card:hover a) {
      color: #34d399 !important;
    }
    
    :global(.post-card p), :global(.text-muted) {
      color: #94a3b8 !important; /* කියවීමට පහසු Slate Text */
    }

    /* Layout Shift බග් එක මඟහැරවූ සුමට Image Hover Effect */
    :global(.featured-slider img), :global(.post-card img) {
      transition: transform 0.5s ease, filter 0.3s ease !important;
      border-radius: 12px !important;
    }
    
    /* කාඩ් එක Hover වෙද්දී ඉමේජ් එකත් සුදුවී ලස්සනට Zoom වීම */
    :global(.post-card:hover img) {
      transform: scale(1.02) !important;
      filter: brightness(1.1) contrast(1.05) !important;
    }
    
    /* සිංහල ෆොන්ට් Render වීම වඩාත් පැහැදිලි කිරීම */
    p, h1, h2, h3, h4, a, span {
      text-rendering: optimizeLegibility !important;
      -webkit-font-smoothing: antialiased !important;
      -moz-osx-font-smoothing: grayscale !important;
    }

    /* Pagination Buttons အඳුරු තීමට ගැළපීම */
    :global(.pagination a) {
      background-color: #0b0c0e !important;
      border: 1px solid #161b22 !important;
      color: #e2e8f0 !important;
      border-radius: 8px !important;
      transition: all 0.2s ease !important;
    }
    :global(.pagination a:hover), :global(.pagination .active a) {
      background-color: #10b981 !important;
      color: #050505 !important;
      border-color: #10b981 !important;
      box-shadow: 0 0 15px rgba(16, 185, 129, 0.4) !important;
    }

    /* Slider එකෙහි කළු පසුබිම් Gradient එක පිරිසිදු කිරීම */
    :global(.featured-slider .slider-content) {
      background: linear-gradient(to top, rgba(5,5,5,1) 0%, rgba(5,5,5,0.5) 60%, transparent 100%) !important;
    }
    
    /* Tags සහ Badges වල වර්ණ පද්ධතිය */
    :global(.tag), :global(.category-badge) {
      background-color: rgba(16, 185, 129, 0.1) !important;
      color: #34d399 !important;
      border: 1px solid rgba(16, 185, 129, 0.2) !important;
      padding: 4px 10px !important;
      border-radius: 6px !important;
    }
  </style>

  {/* පසුබිම් තීම් එක සහ සිලෙක්ෂන් කලර්ස් */}
  <section class="section pt-4 pb-12 min-h-screen bg-[#050505] text-slate-200 selection:bg-emerald-500 selection:text-neutral-950 tracking-wide leading-relaxed antialiased">
    <div class="container">
      
      {/* 🚀 PERFECT SEO HIDDEN BLOCK: 
          පරිශීලකයාට පිටුව ඇතුළත දර්ශනය නොවේ, නමුත් Google බොට්ස් ලා H1 මාතෘකාව සම්පූර්ණයෙන්ම කියවයි. */}
      <div class="sr-only">
        <h1>සිංහල වල් katha</h1>
        <p>Sinhala Wal Katha & Wela Katha Stories - නවතම කතා එකතුව</p>
      </div>

      {/* Slider එක */}
      <FeaturedSlider posts={sortedPosts} />

      {/* ප්‍රධාන පෝස්ට් ග්‍රිඩ් එක */}
      <Posts posts={currentPosts} className="mb-16" />
      
      {/* Pagination */}
      <Pagination currentPage={1} totalPages={totalPages} />
      
    </div>
  </section>
</Base>
