---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

export async function getStaticPaths() {
  const posts = await getSinglePage("posts");
  // ස්වයංක්‍රීය නිවැරදි කිරීම: posts හිස් වුවහොත් ව්‍යුහය බිඳ වැටීම වළක්වයි
  const safePosts = Array.isArray(posts) ? posts : [];
  const paginationLimit = config?.settings?.pagination || 8;
  const totalPages = Math.ceil(safePosts.length / paginationLimit);
  const paths = [];

  for (let i = 1; i < totalPages; i++) {
    paths.push({
      params: {
        slug: (i + 1).toString(),
      },
    });
  }
  return paths;
}

const { slug } = Astro.params;
const posts = await getSinglePage("posts");
const safePosts = Array.isArray(posts) ? posts : [];
const sortedPosts = sortByDate(safePosts);

const paginationLimit = config?.settings?.pagination || 8;
const totalPages = Math.ceil(safePosts.length / paginationLimit);

// 🛠️ CRITICAL LOGIC FIX: පිටු අංකය පරාසයෙන් බැහැර නම් ස්වයංක්‍රීයව පාලනය කිරීම
let currentPage = slug && !isNaN(Number(slug)) ? Number(slug) : 1;
if (currentPage < 1) currentPage = 1;
if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

const indexOfLastPost = currentPage * paginationLimit;
const indexOfFirstPost = indexOfLastPost - paginationLimit;
const currentPosts = sortedPosts && sortedPosts.length > 0 ? sortedPosts.slice(indexOfFirstPost, indexOfLastPost) : [];

// 📈 SEO ප්‍රශස්තකරණය: එක් එක් Pagination පිටුව සඳහා වෙන වෙනම Meta Data සකස් කිරීම
const metaTitle = `${config?.site?.title || "Wala Katha"} - Page ${currentPage}`;
const metaDescription = `අපේ වෙබ් අඩවියේ ඇති නවතම බ්ලොග් ලිපි සහ කතා සියල්ල මෙතැනින් එකම තැනකින් කියවන්න. (පිටුව ${currentPage})`;

const base_url = (config?.site?.base_url || "").replace(/\/$/, ""); 
const canonicalUrl = `${base_url}/page/${currentPage}`;

// SEO Pagination Links (Google Bot එක පිටු අතර නිවැරදිව හුවමාරු වීමට)
const prevUrl = currentPage === 2 ? `${base_url}/` : `${base_url}/page/${currentPage - 1}`;
const nextUrl = currentPage < totalPages ? `${base_url}/page/${currentPage + 1}` : null;

// ⚡ SEO BEST PRACTICE: සෙවුම් යන්ත්‍ර වලට Pagination පිටු 2, 3 නිවැරදිව ලැයිස්තුගත කිරීමට අවසර දීම
const robotsMeta = "index, follow";
---

<Base
  title={metaTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  prev={prevUrl}
  next={nextUrl}
  robots={robotsMeta}
>
  {/* 100% Original Section Layout structure */}
  <section class="section">
    <div class="container">
      {currentPosts && currentPosts.length > 0 ? (
        <Posts className="mb-16" posts={currentPosts} />
      ) : (
        // Original Style එක වෙනස් නොකර දත්ත නොමැති විට පෙන්වන කොටස
        <div class="py-12 text-center opacity-60">
          <p>ලිපි කිසිවෙකු හමුනොවීය.</p>
        </div>
      )}
      
      {totalPages > 1 && (
        <Pagination totalPages={totalPages} currentPage={currentPage} />
      )}
    </div>
  </section>
</Base>
