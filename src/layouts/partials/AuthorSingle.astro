---
import Social from "@/components/Social.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";

const { author } = Astro.props;
const { title, image, social } = author.data;
const { Content } = await render(author);

// Astro සයිට් එකේ දැනට බලන පිටුවේ සම්පූර්ණ URL එක ගැනීම
const currentUrl = Astro.url.href;

// social කියන දත්තය Array එකක්ද කියලා 100%ක්ම තහවුරු කරගැනීම (ලෙඩ නොවෙන්න)
const socialLinks = Array.isArray(social) 
  ? social.map((item: { url: string }) => item.url).filter(Boolean)
  : [];

// Google වෙනුවෙන් පිරිසිදු JSON-LD Schema Markup එක සකස් කිරීම
const authorSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": title,
    "url": currentUrl,
    ...(image && { "image": new URL(image, Astro.site || currentUrl).href }),
    ...(socialLinks.length > 0 && { "sameAs": socialLinks })
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(authorSchema)} />

<section class="section">
  <div class="container">
    <div class="mb-4 text-center md:px-24">
      {
        image && (
          <div class="mb-8">
            <Image
              src={image}
              class="mx-auto rounded-lg"
              height={150}
              width={150}
              alt={title}
            />
          </div>
        )
      }
      <h1 set:html={markdownify(title)} class="page-heading h2 mb-8" />

      <Social source={social} className="social-icons-simple" />
      <div class="content">
        <Content />
      </div>
    </div>
  </div>
</section>
