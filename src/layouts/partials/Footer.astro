---
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";
import { markdownify } from "@/lib/utils/textConverter";
---

{/* 👑 3D SEAMLESS PREMIUM FOOTER:
    සයිට් එකේ ප්‍රධාන පසුබිමෙන් කපලා වෙන් නොකර, උඩින් පට්ටම ලස්සන සියුම් 3D Gradient Glow ලයින් එකක් (to-t from-black) දාලා,
    පහළට යද්දී සියුම් ලෙස වෙනස් වන වෘත්තීය මට්ටමේ අලුත් ස්ටයිල් එකක් දුන්නා */}
<footer class="relative mt-auto border-t border-gradient-to-r border-t-white/[0.03] bg-gradient-to-b from-[#010203] via-[#05070a] to-[#080b11] py-12 select-none">
  
  {/* 3D Depth Top Lighting Layer: ෆුටර් එක පටන් ගන්න තැන සයිට් එක ඇතුළට කිඳා බැහැලා තියෙනවා වගේ 3D ලුක් එකක් දෙන සියුම් සෙවනැල්ල */}
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-[#01AD9F]/20 to-transparent shadow-[0_-3px_20px_rgba(1,173,159,0.15)]"></div>

  <div class="container relative z-10 text-center">
    
    {/* 📋 FOOTER NAVIGATION MENU */}
    <ul class="mb-8 flex flex-wrap justify-center items-center gap-x-2 gap-y-4">
      {
        menu.footer.map((item) => (
          <li class="inline-block">
            <a
              href={item.url}
              /* 🎯 CONTRAST & UI FIX: සාමාන්‍ය වෙලාවට මෘදු සුදු (#F8F8FF/70) දීලා, හොවර් එකේදී සයිට් එකේ තීම් Teal (#01AD9F) වර්ණයෙන් බැබළෙන්න හැදුවා */
              class="px-4 py-2 text-sm font-medium text-[#F8F8FF]/70 tracking-wide transition-all duration-300 hover:text-[#01AD9F] hover:drop-shadow-[0_0_6px_rgba(1,173,159,0.4)]"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>

    {/* 📱 SOCIAL MEDIA ICONS CONTAINER */}
    {/* සෝෂල් අයිකන මැදට ගෙන ඒම සහ පරතරය නූලට හැදීම */}
    <div class="flex justify-center mb-8 scale-105">
      <Social source={social.main} className="social-icons-footer" />
    </div>

    {/* 📑 HORIZONTAL SEPARATOR */}
    <hr class="border-white/[0.04] max-w-xs mx-auto mb-6" />

    {/* 🔏 COPYRIGHT TEXT */}
    {/* 🎯 SEO ACCESSIBILITY SCORE: Google Bot එකට නූලටම කියවන්න පුළුවන් වර්ණ අනුපාතයකින් (text-white/50) සකස් කිරීම */}
    <p 
      set:html={markdownify(config.params.copyright)} 
      class="text-xs sm:text-sm text-[#F8F8FF]/50 font-medium tracking-wider leading-relaxed prose-a:text-[#01AD9F] prose-a:no-underline hover:prose-a:underline" 
    />

  </div>
</footer>
