---
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";
import { markdownify } from "@/lib/utils/textConverter";
---

{/* 👑 GLOSSY 3D GLASSMORPHISM FOOTER WRAPPER */}
<footer 
  class="relative mt-12 py-12 overflow-hidden border-t border-white/[0.12] bg-gradient-to-b from-white/[0.04] to-white/[0.01] backdrop-blur-xl shadow-[inset_0_2px_4px_rgba(255,255,255,0.15),0_12px_40px_rgba(0,0,0,0.8)]"
  role="contentinfo"
>
  {/* ✨ REAL GLOSSY REFLECTION */}
  <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/[0.03] to-white/[0.05] pointer-events-none"></div>
  <div class="absolute top-0 left-1/4 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-white/40 to-transparent blur-[0.5px]"></div>

  <div class="container relative z-10 text-center select-none">
    
    {/* 📋 FOOTER MENU */}
    <ul class="mb-8 flex flex-wrap justify-center gap-x-2 gap-y-3">
      {
        menu.footer.map((menu) => (
          <li class="inline-block">
            <a
              href={menu.url}
              class="px-4 py-2 text-sm font-semibold text-white/80 transition-all duration-300 hover:text-[#01AD9F] hover:drop-shadow-[0_0_8px_rgba(1,173,159,0.5)]"
            >
              {menu.name}
            </a>
          </li>
        ))
      }
    </ul>

    {/* 👑 EXPANDED 3D DEEP HORIZONTAL CONTAINER */}
    {/* 🎯 FIX: මුළු පිටුවේම පළල ලස්සනට කවර් වෙන්න max-w-5xl කරලා, ඇතුළත padding වැඩි කළා */}
    <div class="w-full max-w-5xl mx-auto mb-10 px-2 sm:px-6">
      <div class="w-full py-6 px-4 sm:px-10 rounded-2xl border border-white/[0.06] bg-gradient-to-b from-[#0b0c0e] to-[#040506] shadow-[inset_0_4px_25px_rgba(0,0,0,0.95),0_2px_4px_rgba(255,255,255,0.03)]">
        {/* Astro Scoping බග් එක නැති කරන්න "social-icons-3d-expanded" ක්ලාස් එක පාවිච්චි කිරීම */}
        <Social source={social.main} className="social-icons-3d-expanded" />
      </div>
    </div>

    {/* 📜 COPYRIGHT TEXT */}
    <p 
      set:html={markdownify(config.params.copyright)} 
      class="text-xs sm:text-sm text-white/40 font-medium tracking-wide prose-a:text-[#01AD9F] prose-a:no-underline hover:prose-a:underline" 
    />
  </div>
</footer>

{/* 🛠️ 100% FIX FOR ASTRO COMPONENT SCOPING BUG (Using :global) */}
<style is:global>
  /* 🎯 CRUCIAL FIX: Social Component එක ඇතුළේ තියෙන <ul> එකට 100% පළල දීලා අයිකන ඈත් කිරීම */
  .social-icons-3d-expanded,
  .social-icons-3d-expanded ul {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important; /* ඈතටම විහිදී යන සේ */
    width: 100% !important;
    gap: 0.75rem !important;
    flex-wrap: nowrap !important; /* මොබයිල් වලදීත් එක පේළියට තියාගැනීමට */
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }
  
  .social-icons-3d-expanded li {
    display: block !important;
    flex: 1 !important; /* හැම එකකටම සමාන පළලක් බෙදා දීම */
    max-w: 75px !important;
  }
  
  .social-icons-3d-expanded a {
    display: flex !important;
    width: 100% !important;
    max-w: 3.5rem;
    height: 3.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.95rem;
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
  }

  .social-icons-3d-expanded svg {
    width: 1.5rem;
    height: 1.5rem;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8)) !important;
  }

  /* ==========================================================
     👑 3D BRAND COLORS - NORMAL STATE (සාමාන්‍ය වෙලාවට කළු-සුදු 3D Mix)
     ========================================================== */
  .social-icons-3d-expanded a:not(:hover) {
    background: linear-gradient(135deg, #222428 0%, #0b0c0e 100%) !important;
    box-shadow: 
      0 6px 12px rgba(0, 0, 0, 0.5), 
      inset 0 1px 1px rgba(255, 255, 255, 0.08), 
      inset 0 -3px 6px rgba(0, 0, 0, 0.7) !important;
    color: #a3a3a3 !important; /* මෘදු සුදු-අළු මික්ස් */
  }

  /* ==========================================================
     👑 SMART 3D BRAND COLORS - HOVER STATE (ඇත්තම නිල වර්ණ)
     ========================================================== */

  /* Facebook */
  .social-icons-3d-expanded a[href*="facebook.com"]:hover {
    border-color: #1877F2 !important;
    color: #ffffff !important;
    background: linear-gradient(135deg, #2482ff 0%, #1059bd 100%) !important;
    box-shadow: 0 12px 24px rgba(24, 119, 242, 0.4), inset 0 1px 2px rgba(255, 255, 255, 0.4) !important;
  }

  /* Twitter / X */
  .social-icons-3d-expanded a[href*="twitter.com"]:hover,
  .social-icons-3d-expanded a[href*="x.com"]:hover {
    border-color: #ffffff !important;
    color: #000000 !important;
    background: linear-gradient(135deg, #ffffff 0%, #cccccc 100%) !important;
    box-shadow: 0 12px 24px rgba(255, 255, 255, 0.25), inset 0 1px 2px rgba(255, 255, 255, 0.5) !important;
  }

  /* YouTube */
  .social-icons-3d-expanded a[href*="youtube.com"]:hover {
    border-color: #FF0000 !important;
    color: #ffffff !important;
    background: linear-gradient(135deg, #ff3333 0%, #990000 100%) !important;
    box-shadow: 0 12px 24px rgba(255, 0, 0, 0.4), inset 0 1px 2px rgba(255, 255, 255, 0.3) !important;
  }

  /* LinkedIn (If exists) */
  .social-icons-3d-expanded a[href*="linkedin.com"]:hover {
    border-color: #0077B5 !important;
    color: #ffffff !important;
    background: linear-gradient(135deg, #0094ff 0%, #005584 100%) !important;
    box-shadow: 0 12px 24px rgba(0, 119, 181, 0.4), inset 0 1px 2px rgba(255, 255, 255, 0.3) !important;
  }

  /* Instagram */
  .social-icons-3d-expanded a[href*="instagram.com"]:hover {
    border-color: #E1306C !important;
    color: #ffffff !important;
    background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%) !important;
    box-shadow: 0 12px 24px rgba(225, 48, 108, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.3) !important;
  }

  /* ⚡ HOVER POP EFFECT */
  .social-icons-3d-expanded a:hover {
    transform: translateY(-8px) scale(1.12) !important; /* පට්ට 3D Pop එකක් */
  }
  
  .social-icons-3d-expanded a:hover svg {
    transform: scale(1.15) !important;
  }
</style>
