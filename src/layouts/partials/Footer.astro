---
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";
import { markdownify } from "@/lib/utils/textConverter";
---

{/* 👑 PREMIUM 3D METALLIC FOOTER WRAPPER:
    - පටන් ගන්න තැන (top) 3D විදිහට ඉස්මතු වෙන්න මෘදු සුදු පැහැති සියුම් Edge එකක් (border-t border-white/20) සහ drop-shadow එකක් දුන්නා.
    - පසුබිම සඳහා දිලිසෙන තද රිදී පැහැයක් එන සේ Metallic Gradient එකක් (from-[#1e2530] via-[#3a4454] to-[#121720]) පාවිච්චි කළා. */}
<footer 
  class="relative mt-12 w-full border-t border-white/20 bg-gradient-to-b from-[#1c2330] via-[#2d3748] to-[#0f141c] py-12 shadow-[0_-15px_30px_rgba(0,0,0,0.8),inset_0_1px_2px_rgba(255,255,255,0.15)] select-none rounded-t-[2.5rem]"
  role="contentinfo"
>
  {/* 3D Reflection Effect: රිදී පැහැය තවදුරටත් දිලිසෙන්න උඩින්ම දාපු සියුම් ආලෝක පටියක් */}
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-white/20 to-transparent blur-[1px]"></div>

  <div class="container mx-auto px-4 text-center">
    
    {/* 🌐 SEO NAVIGATION MENU */}
    <nav aria-label="Footer Navigation" class="mb-8">
      <ul class="flex flex-wrap justify-center items-center gap-x-2 gap-y-4">
        {
          menu.footer.map((item) => (
            <li class="inline-block">
              <a
                href={item.url}
                /* 🎯 CONTRAST FIX: තද රිදී පසුබිම මත අකුරු සුපිරියටම කියවන්න පුළුවන් වෙන්න text-slate-200 දමා, 
                   හොවර් වීමේදී සයිට් එකේ තීම් Teal (#01AD9F) එකෙන් දිලිසෙන්න හැදුවා */
                class="px-4 py-2 text-sm font-bold text-slate-200 hover:text-[#01AD9F] transition-all duration-300 hover:drop-shadow-[0_0_8px_rgba(1,173,159,0.6)]"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* 📱 SOCIAL ICONS */}
    {/* සෝෂල් අයිකන ටික රිදී පසුබිම මත පට්ටම ලස්සනට වෙන් වෙලා පේන්න scale කරලා ගත්තා */}
    <div class="mb-8 flex justify-center text-slate-100 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">
      <Social source={social.main} className="social-icons scale-110" />
    </div>

    {/* HORIZONTAL SEPARATOR */}
    <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent mx-auto mb-6"></div>

    {/* 👑 COPYRIGHT TEXT */}
    {/* සෙවුම් යන්ත්‍ර වලට සහ යූසර්ට පිරිසිදුව පෙනෙන්න text-xs සහ 60% ක් රිදී පැහැයට හැරෙව්වා */}
    <p 
      set:html={markdownify(config.params.copyright)} 
      class="text-xs sm:text-sm text-slate-400 font-medium tracking-wide drop-shadow-[0_1px_2px_rgba(0,0,0,0.4)]" 
    />
  </div>

  {/* 3D Bottom Curve Popup: අවසන් වෙන තැන පට්ටම Clean 3D Finish එකක් දීමට (සයිට් එකේ අන්තිම කෙළවර) */}
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#0f141c] shadow-[inset_0_-2px_4px_rgba(0,0,0,0.9)]"></div>
</footer>
