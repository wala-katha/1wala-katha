---
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";
import { markdownify } from "@/lib/utils/textConverter";
---

{/* 👑 GLOSSY 3D GLASSMORPHISM FOOTER WRAPPER */}
<footer 
  class="relative mt-12 py-12 overflow-hidden border-t border-white/[0.12] bg-gradient-to-b from-white/[0.04] to-white/[0.01] backdrop-blur-xl shadow-[inset_0_2px_4px_rgba(255,255,255,0.15),0_12px_40px_rgba(0,0,0,0.8)]"
  role="contentinfo"
>
  {/* ✨ REAL GLOSSY REFLECTION */}
  <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/[0.03] to-white/[0.05] pointer-events-none"></div>
  <div class="absolute top-0 left-1/4 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-white/40 to-transparent blur-[0.5px]"></div>

  <div class="container relative z-10 text-center select-none">
    
    {/* 📋 FOOTER MENU */}
    <ul class="mb-8 flex flex-wrap justify-center gap-x-2 gap-y-3">
      {
        menu.footer.map((menu) => (
          <li class="inline-block">
            <a
              href={menu.url}
              class="px-4 py-2 text-sm font-semibold text-white/80 transition-all duration-300 hover:text-[#01AD9F] hover:drop-shadow-[0_0_8px_rgba(1,173,159,0.5)]"
            >
              {menu.name}
            </a>
          </li>
        ))
      }
    </ul>

    {/* 👑 EXPANDED 3D DEEP HORIZONTAL CONTAINER (පිටුවේ පළලට යන 3D ලොකු කොටුව) */}
    <div class="w-full max-w-4xl mx-auto mb-10 px-4 sm:px-8">
      <div class="w-full py-6 px-6 sm:px-12 rounded-2xl border border-white/[0.06] bg-gradient-to-b from-[#0b0c0e] to-[#040506] shadow-[inset_0_4px_20px_rgba(0,0,0,0.9),0_2px_4px_rgba(255,255,255,0.03)]">
        {/* අයිකන එකිනෙකට ඈත් කර පෙන්වන 3D ක්ලාස් එක */}
        <Social source={social.main} className="social-icons-3d-expanded" />
      </div>
    </div>

    {/* 📜 COPYRIGHT TEXT */}
    <p 
      set:html={markdownify(config.params.copyright)} 
      class="text-xs sm:text-sm text-white/40 font-medium tracking-wide prose-a:text-[#01AD9F] prose-a:no-underline hover:prose-a:underline" 
    />
  </div>
</footer>

{/* 🛠️ ADVANCED 3D BRAND-COLORED STYLE INJECTION */}
<style is:global>
  /* ලොකු කොටුව ඇතුළේ අයිකන පිටුවේ පලලට ඈත් කිරීම */
  .social-icons-3d-expanded ul {
    display: flex;
    align-items: center;
    /* 🎯 පිටුවේ පළලට සමානව අයිකන එකිනෙකට ඈත් කිරීම (Space Between/Around වෙනුවට මුළු ඉඩම බෙදා ගැනීම) */
    justify-content: space-around; 
    gap: 1.5rem;
    flex-wrap: wrap;
    width: 100%;
    margin: 0;
    padding: 0;
  }
  
  .social-icons-3d-expanded li {
    display: inline-block;
    flex-grow: 1;
    max-w: 60px; /* මොබයිල් වලදී ඕනෑවට වඩා විශාල වීම වැළැක්වීමට */
  }
  
  .social-icons-3d-expanded a {
    display: flex;
    width: 3.2rem;
    height: 3.2rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.85rem;
    margin: 0 auto;
    
    /* 📦 අයිකන වටේ තියෙන බෝඩර් ලයින් එක */
    border: 1px solid rgba(255, 255, 255, 0.08);
    
    /* 🖤 Base 3D Dark Matte Background */
    background: linear-gradient(135deg, #1e2024 0%, #0f1012 100%);
    
    /* 3D Shadows */
    box-shadow: 
      0 6px 12px rgba(0, 0, 0, 0.6), 
      inset 0 1px 1px rgba(255, 255, 255, 0.08), 
      inset 0 -3px 6px rgba(0, 0, 0, 0.7);
      
    color: #9ca3af;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* Smooth Pop-out effect */
  }

  .social-icons-3d-expanded svg {
    width: 1.4rem;
    height: 1.4rem;
    transition: transform 0.3s ease;
  }

  /* ==========================================================
     👑 SMART 3D BRAND COLORS ON HOVER (සොසල් මීඩියා වල ඇත්තම පාට)
     ========================================================== */

  /* Facebook - #1877F2 */
  .social-icons-3d-expanded a[href*="facebook.com"]:hover {
    border-color: #1877F2;
    color: #ffffff;
    background: linear-gradient(135deg, #2482ff 0%, #1059bd 100%);
    box-shadow: 0 10px 20px rgba(24, 119, 242, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.3);
  }

  /* Twitter / X - #1DA1F2 or White/Black (කළු සයිට් එකට ගැළපෙන්න Electric White/Cyan) */
  .social-icons-3d-expanded a[href*="twitter.com"]:hover,
  .social-icons-3d-expanded a[href*="x.com"]:hover {
    border-color: #f3f4f6;
    color: #000000;
    background: linear-gradient(135deg, #ffffff 0%, #e5e7eb 100%);
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.25), inset 0 1px 2px rgba(255, 255, 255, 0.5);
  }

  /* YouTube - #FF0000 */
  .social-icons-3d-expanded a[href*="youtube.com"]:hover {
    border-color: #FF0000;
    color: #ffffff;
    background: linear-gradient(135deg, #ff2626 0%, #b30000 100%);
    box-shadow: 0 10px 20px rgba(255, 0, 0, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.3);
  }

  /* WhatsApp - #25D366 */
  .social-icons-3d-expanded a[href*="whatsapp.com"]:hover {
    border-color: #25D366;
    color: #ffffff;
    background: linear-gradient(135deg, #30e875 0%, #1a9e47 100%);
    box-shadow: 0 10px 20px rgba(37, 211, 102, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.3);
  }

  /* Telegram - #26A5E4 */
  .social-icons-3d-expanded a[href*="telegram.org"]:hover,
  .social-icons-3d-expanded a[href*="t.me"]:hover {
    border-color: #26A5E4;
    color: #ffffff;
    background: linear-gradient(135deg, #33b5f7 0%, #1b7cb0 100%);
    box-shadow: 0 10px 20px rgba(38, 165, 228, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.3);
  }

  /* Pinterest - #BD081C */
  .social-icons-3d-expanded a[href*="pinterest.com"]:hover {
    border-color: #BD081C;
    color: #ffffff;
    background: linear-gradient(135deg, #d61126 0%, #8c0512 100%);
    box-shadow: 0 10px 20px rgba(189, 8, 28, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.3);
  }

  /* GitHub - #181717 */
  .social-icons-3d-expanded a[href*="github.com"]:hover {
    border-color: #6e5494;
    color: #ffffff;
    background: linear-gradient(135deg, #403060 0%, #181717 100%);
    box-shadow: 0 10px 20px rgba(110, 84, 148, 0.35), inset 0 1px 2px rgba(255, 255, 255, 0.2);
  }

  /* ⚡ HOVER GLOBAL ACTION */
  .social-icons-3d-expanded a:hover {
    transform: translateY(-6px) scale(1.1); /* 3D Pop-up */
  }
  
  .social-icons-3d-expanded a:hover svg {
    transform: scale(1.15); /* Icon zoom */
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));
  }
</style>
