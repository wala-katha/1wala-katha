---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/layouts/components/SimilarPosts.astro"; // ⚠️ FIXED: නිවැරදි ෆෝල්ඩර් පාත් එකට අප්ඩේට් කළා
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, authors, categories, image, date, tags } =
  post.data;

// 🎯 SMART SEO RELATED POSTS LOGIC:
// 1. දැනට කියවන පෝස්ට් එක අයින් කර සමාන කැටගරි තියෙන පෝස්ට් පෙරීම
let smartSimilarPosts = posts.filter(
  (p) => p.id !== post.id && p.data.categories?.some((cat) => categories?.includes(cat))
);

// 2. ⚡ SEO FALLBACK: සමාන කැටගරි නැත්නම්, සයිට් එකේ තියෙන වෙනත් ඕනෑම පෝස්ට් ඔටෝ අරන් පෙන්වීම (හිස්ව තැබීම SEO වලට අහිතකරයි)
if (!smartSimilarPosts || smartSimilarPosts.length === 0) {
  smartSimilarPosts = posts.filter((p) => p.id !== post.id);
}

// 3. FIX: උඹ ඉල්ලපු විදිහටම කෙළින් අතට (2:3) ලස්സනට පේළියට වාඩි වෙන්න පෝස්ට් ප්‍රමාණය 6ක් දක්වා වැඩි කළා
const finalSimilarPosts = smartSimilarPosts.slice(0, 6);
---

{/* 🎯 SEO FIX: මුළු සෙක්ෂන් එකම Google Rich Snippets වලට අහුවෙන්න BlogPosting Schema ඇතුළත් කළා */}
<section class="section bg-[#010203]" itemscope itemtype="http://schema.org/BlogPosting">
  <div class="container">
    <article class="row justify-center">
      {/* POST TITLE: ප්‍රධාන මාතෘකාව #F8F8FF වලින් උපරිම සුදු කර ඉස්මතු කළා */}
      <div class="md:col-10 text-center">
        <h1 itemprop="headline" set:html={markdownify(title)} class="h2 text-[#F8F8FF] font-black drop-shadow-md" />
        
        {/* META INFO ROW: මෙටා ඩේටා සහ අයිකන කළු පසුබිමට කැපී පෙනෙන සේ සැකසීම */}
        <ul class="mt-4 flex flex-wrap items-center justify-center text-[#F8F8FF]/90">
          <li class="mx-3" itemprop="author" itemscope itemtype="http://schema.org/Person">
            {
              allAuthors
                .filter((author) =>
                  authors
                    .map((author: string) => slugify(author))
                    .includes(slugify(author.data.title))
                )
                .map((author) => (
                  <a
                    itemprop="url"
                    href={`/authors/${slugify(author.id)}`}
                    class="flex items-center hover:text-primary font-bold text-[#F8F8FF]"
                  >
                    {author.data.image && (
                      <Image
                        src={author.data.image}
                        alt={author.data.title}
                        height={50}
                        width={50}
                        class="mr-2 h-6 w-6 rounded-full border border-white/20"
                        itemprop="image"
                      />
                    )}
                    <span itemprop="name">{author.data.title}</span>
                  </a>
                ))
            }
          </li>
          <li class="mx-3 flex items-center flex-wrap font-semibold text-[#F8F8FF]">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-[#01AD9F]" />
            <time datetime={date} itemprop="datePublished">{dateFormat(date)}</time>
          </li>
          <li class="mx-3 flex items-center flex-wrap">
            <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-[#01AD9F]" />

            <ul>
              {
                categories.map((category: string, i: number) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}`}
                      class="mr-2 hover:text-primary font-bold bg-white/10 px-2 py-0.5 rounded text-[#F8F8FF]"
                    >
                      {humanize(category)}
                      {i !== categories.length - 1 && ","}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {
          image && (
            <Image
              src={image}
              height={500}
              width={1000}
              alt={title}
              class="rounded-lg w-full h-auto object-cover mx-auto max-w-4xl border border-white/10"
              loading="eager"
              itemprop="image"
            />
          )
        }
      </div>

      <div class="md:col-10">
        {/* 👑 ULTIMATE POST CONTENT TYPOGRAPHY FIX: 
            පෝස්ට් එකේ අකුරු වල පැහැදිලි බව (Readability) සහ Google SEO Counter එක උපරිම කිරීමට 
            itemprop="articleBody" සහ නවීන ඩාර්ක් ස්ටයිලින් යෙදුවා */}
        <div itemprop="articleBody" class="content mb-16 text-left text-[#E2E8F0] custom-post-content prose prose-invert max-w-none">
          <Content />
        </div>
        
        {/* TAGS BLOCK: තද කහ පැහැති පසුබිම සහ කළු අකුරු වලින් බොත්තම් සකස් කළා */}
        <div class="flex flex-wrap items-center justify-between border-t border-white/10 pt-6">
          <ul class="mr-4 mb-4 space-x-3">
            {
              tags.map((tag: string) => (
                <li class="inline-block">
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="block rounded-lg bg-[#FFCC00] border border-[#FFCC00] px-4 py-2 font-black text-[#010203] text-sm hover:bg-[#E6B800] transition duration-300"
                  >
                    #{humanize(tag)}
                  </a>
                </li>
              ))
            }
          </ul>
          <Share
            className="social-share mb-4 text-[#F8F8FF]"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>
      </div>
    </article>
  </div>
</section>

{/* 👑 SUGGESTED STORIES BLOCK:
    1. පසුබිම: කළු ➔ තද කොළ ➔ කළු (from-[#010203] via-[#022c16] to-[#010203]) 3-Way Gradient එකක් දැම්මා.
    2. 🎯 SEO FIX: Heading Hierarchy එක නිවැරදි කිරීමට මෙතන තිබූ h2 එක h3 දක්වා වෙනස් කළා (Semantic HTML). */}
{
  finalSimilarPosts.length > 0 && (
    <section class="section pt-12 pb-16 bg-gradient-to-b from-[#010203] via-[#022c16] to-[#010203] border-t border-white/5">
      <div class="container">
        {/* ටයිටල් එක හරියටම මැදට (text-center) ගෙන, පැති බෝඩර් ඉවත් කර පිරිසිදු තද සුදු කර ඉස්මතු කළා */}
        <h3 class="mb-8 font-black text-center h4 text-[#F8F8FF]">
          ඔබ කැමති විය හැකි තවත් කතා (Suggested Stories)
        </h3>
        
        <div class="row">
          <SimilarPosts posts={finalSimilarPosts} />
        </div>
      </div>
    </section>
  )
}

{/* ⚡ SCOPED CSS FOR ADVANCED TYPOGRAPHY COMPATIBILITY:
    කළු පසුබිමක දිගු ලිපි කියවීමේදී ඇස් වෙහෙසට පත් නොවන ලෙස ප්‍රධාන ඡේද සියුම් Off-white (e2e8f0) කර,
    මාතෘකා සහ තද අකුරු (strong) පිරිසිදු තද සුදු (#F8F8FF) වන සේ නිවැරදි කළා. */}
<style is:global>
  .custom-post-content p, 
  .custom-post-content li {
    color: #E2E8F0 !important;
    line-height: 1.8 !important;
    font-size: 1.125rem !important;
  }
  .custom-post-content span,
  .custom-post-content strong,
  .custom-post-content h1,
  .custom-post-content h2,
  .custom-post-content h3,
  .custom-post-content h4 {
    color: #F8F8FF !important;
    font-weight: 800 !important;
  }
  .custom-post-content blockquote {
    border-left: 4px solid #01AD9F !important;
    background: rgba(255, 255, 255, 0.03);
    padding: 1rem;
    border-radius: 0.5rem;
  }
  .custom-post-content blockquote p {
    color: #CBD5E1 !important;
    font-style: italic;
  }
</style>
