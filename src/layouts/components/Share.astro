---
import config from "@/config/config.json";
import {
  IoLogoFacebook,
  IoLogoLinkedin,
  IoLogoPinterest,
  IoLogoTwitter,
  IoLogoWhatsapp,
} from "react-icons/io5";
import { FaTelegram } from "react-icons/fa6";

const { base_url } = config.site;
const { title, description, slug, className } = Astro.props;
---

{/* 👑 PREMIUM LARGE SOCIAL SHARE LIST: 
    බොත්තම් ලොකු කරපු නිසා ඒවා එකිනෙක නොගැටී පිරිසිදුව පෙනීමට gap-3.5 සහ sm:gap-4.5 දක්වා පරතරය වැඩි කළා */}
<ul class={`flex flex-wrap items-center gap-3.5 sm:gap-4.5 select-none ${className}`}>
  
  {/* FACEBOOK */}
  <li class="inline-block">
    <a
      aria-label="facebook share button"
      href={`https://facebook.com/sharer/sharer.php?u=${base_url}/${slug}`}
      target="_blank"
      rel="noreferrer noopener nofollow"
      /* 🎯 UI HIGHLIGHT FIX: බොත්තම් h-11 w-11 (මොබයිල්) සහ sm:h-12 sm:w-12 (ඩෙස්ක්ටොප්) දක්වා විශාල කර, 
         අයිකන වල ප්‍රමාණය text-xl sm:text-2xl ලෙස උපරිම පැහැදිලි මට්ටමට ගෙන ආවා */
      class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[#1877F2] transition duration-300 hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2] hover:shadow-[0_0_15px_rgba(24,119,242,0.6)] text-xl sm:text-2xl"
    >
      <IoLogoFacebook />
    </a>
  </li>
  
  {/* TWITTER (X) */}
  <li class="inline-block">
    <a
      aria-label="twitter share button"
      href={`https://twitter.com/intent/tweet/?text=${encodeURIComponent(title)}&url=${base_url}/${slug}`}
      target="_blank"
      rel="noreferrer noopener nofollow"
      class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[#F8F8FF] transition duration-300 hover:bg-[#F8F8FF] hover:text-[#010203] hover:border-white text-xl sm:text-2xl"
    >
      <IoLogoTwitter />
    </a>
  </li>

  {/* WHATSAPP */}
  <li class="inline-block">
    <a
      aria-label="whatsapp share button"
      href={`https://api.whatsapp.com/send?text=${encodeURIComponent(title)}%20-%20${base_url}/${slug}`}
      target="_blank"
      rel="noreferrer noopener nofollow"
      class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[#25D366] transition duration-300 hover:bg-[#25D366] hover:text-white hover:border-[#25D366] hover:shadow-[0_0_15px_rgba(37,211,102,0.6)] text-xl sm:text-2xl"
    >
      <IoLogoWhatsapp />
    </a>
  </li>

  {/* TELEGRAM */}
  <li class="inline-block">
    <a
      aria-label="telegram share button"
      href={`https://t.me/share/url?url=${base_url}/${slug}&text=${encodeURIComponent(title)}`}
      target="_blank"
      rel="noreferrer noopener nofollow"
      class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[#26A5E4] transition duration-300 hover:bg-[#26A5E4] hover:text-white hover:border-[#26A5E4] hover:shadow-[0_0_15px_rgba(38,165,228,0.6)] text-xl sm:text-2xl"
    >
      <FaTelegram />
    </a>
  </li>

  {/* LINKEDIN */}
  <li class="inline-block">
    <a
      aria-label="linkedin share button"
      href={`https://www.linkedin.com/shareArticle?mini=true&url=${base_url}/${slug}&title=${encodeURIComponent(title)}&summary=${encodeURIComponent(description)}&source=${base_url}`}
      target="_blank"
      rel="noreferrer noopener nofollow"
      class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[#0077B5] transition duration-300 hover:bg-[#0077B5] hover:text-white hover:border-[#0077B5] hover:shadow-[0_0_15px_rgba(0,119,181,0.6)] text-xl sm:text-2xl"
    >
      <IoLogoLinkedin />
    </a>
  </li>

  {/* PINTEREST */}
  <li class="inline-block">
    <a
      aria-label="pinterest share button"
      href={`https://pinterest.com/pin/create/button/?url=${base_url}/${slug}&media=&description=${encodeURIComponent(description)}`}
      target="_blank"
      rel="noreferrer noopener nofollow"
      class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[#BD081C] transition duration-300 hover:bg-[#BD081C] hover:text-white hover:border-[#BD081C] hover:shadow-[0_0_15px_rgba(189,8,28,0.6)] text-xl sm:text-2xl"
    >
      <IoLogoPinterest />
    </a>
  </li>
</ul>
