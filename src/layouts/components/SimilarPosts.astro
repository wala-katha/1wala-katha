---
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
};
const { posts } = Astro.props;
---

<div class="row gy-4 gx-2 sm:gx-4 justify-center">
  {
    posts.map((post, i: number) => (
      /* SMART GRID FIX: මොබයිල් ඇතුළු හැම තිරයකදීම එක පේළියට පෝස්ට් 3ක් පෙන්වීමට col-4 යෙදුවා */
      <div class="col-4 flex flex-col justify-between group">
        {post.data.image && (
          <a
            href={`/blog/${post.id}/`}
            class="rounded-lg block hover:text-primary overflow-hidden group relative bg-gray-900"
            style="aspect-ratio: 2 / 3;" /* හෝම් පේජ් එකේ වගේම ලස්සන 2:3 Ratio එක දුන්නා */
          >
            <Image
              class="group-hover:scale-[1.04] transition duration-300 w-full h-full object-contain"
              src={post.data.image}
              alt={post.data.title}
              width={500}
              height={750}
              loading="lazy"
              decoding="async"
            />
          </a>
        )}
        
        {/* INFO ROW: මොබයිල් වලට ගැළපෙන සේ අකුරු කුඩා කළා */}
        <ul class="mt-2 mb-1 flex flex-wrap items-center text-text text-[10px] sm:text-sm justify-between">
          <li class="flex items-center flex-wrap">
            <BiCategoryAlt className="mr-0.5 h-3 w-3 sm:h-[16px] sm:w-[16px] text-gray-600" />
            <ul>
              {post.data.categories.slice(0, 1).map((category: string) => (
                <li class="inline-block">
                  <a
                    href={`/categories/${slugify(category)}/`}
                    class="hover:text-primary font-bold text-[9px] sm:text-xs bg-gray-100 dark:bg-darkmode-theme-light px-1 sm:px-2 py-0.5 rounded"
                  >
                    {humanize(category)}
                  </a>
                </li>
              ))}
            </ul>
          </li>
          <li class="hidden xs:flex items-center flex-wrap font-medium text-[9px] sm:text-xs text-gray-500">
            <BiCalendarEdit className="mr-0.5 h-3 w-3 sm:h-4 sm:w-4" />
            {dateFormat(post.data.date!)}
          </li>
        </ul>

        {/* POST TITLE: line-clamp-2 දමා පේළි දෙකකට සීමා කළා */}
        <h3 class="mb-1 line-clamp-2 leading-tight">
          <a
            href={`/blog/${post.id}/`}
            class="block hover:text-primary transition duration-300 text-xs sm:text-base font-bold"
          >
            {post.data.title}
          </a>
        </h3>
      </div>
    ))
  }
</div>
