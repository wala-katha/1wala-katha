---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg select-none" id="astro-featured-slider">
  
  {/* SLIDER IMAGES CONTAINER */}
  <div class="relative w-full aspect-[16/7] sm:aspect-[21/7] md:aspect-[24/7] bg-gray-900 overflow-hidden" id="slider-view-box">
    {demoSlides.map((slide, index) => (
      <div 
        class="absolute inset-0 w-full h-full slide-item transition-all duration-[1200ms] ease-in-out"
        style={`opacity: ${index === 0 ? '1' : '0'}; z-index: ${index === 0 ? '10' : '0'}; filter: blur(0px);`}
        data-slide-index={index}
      >
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" title={slide.title}>
          {/* MAXIMUM CLARITY FIX: Astro Image Optimization හරහා ගුණාත්මකභාවය 100% ක්ම තබා ගනිමින්, කිසිදු අඳුරු ශේඩින් එකක් නැතිව මුල් පිටපතේ පිරිසිදු නිමාව ලබා දීම */}
          <Image
            src={slide.image}
            alt={slide.title}
            width={1200}
            height={525}
            quality={100} 
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            class="w-full h-full object-cover object-center transition duration-700 group-hover:scale-[1.01]"
          />
          
          {/* ONLY CATEGORY TAG OVERLAY */}
          <div class="absolute bottom-3 left-4 z-20">
            <span class="bg-primary text-white px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md pointer-events-none">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}

    {/* 🧩 FINE PARTICLES ANIMATION CANVAS LAYER */}
    <canvas id="particle-transition-canvas" class="absolute inset-0 pointer-events-none z-30 hidden w-full h-full"></canvas>
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-20">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

{/* SMOOTH PARTICLES & BLUR TRANSITION SCRIPT */}
<script>
  function initFineParticleSlider() {
    const slider = document.getElementById('astro-featured-slider');
    if (!slider) return;

    const slides = slider.querySelectorAll('.slide-item') as NodeListOf<HTMLElement>;
    const dots = slider.querySelectorAll('.slider-dot');
    const canvas = slider.querySelector('#particle-transition-canvas') as HTMLCanvasElement;
    
    if (slides.length === 0 || dots.length === 0 || !canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let currentIndex = 0;
    const totalSlides = slides.length;
    const intervalTime = 5000; 
    let slideInterval: any;
    let isAnimating = false;

    function resizeCanvas() {
      canvas.width = canvas.parentElement ? canvas.parentElement.offsetWidth : canvas.offsetWidth;
      canvas.height = canvas.parentElement ? canvas.parentElement.offsetHeight : canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    class Particle {
      x: number;
      y: number;
      size: number;
      speedY: number;
      alpha: number;
      fadeSpeed: number;

      constructor(startX: number, startY: number) {
        this.x = startX;
        this.y = startY;
        this.size = Math.random() * 2.5 + 1.5;
        this.speedY = -(Math.random() * 2 + 1.5);
        this.alpha = 1;
        this.fadeSpeed = Math.random() * 0.015 + 0.008;
      }

      update() {
        this.y += this.speedY;
        this.alpha -= this.fadeSpeed;
      }

      draw(context: CanvasRenderingContext2D) {
        context.save();
        context.globalAlpha = Math.max(0, this.alpha);
        context.fillStyle = '#ff3366'; // සයිට් එකේ Primary Theme එකට ගැළපෙන ලස්සන අංශු (Particles)
        context.beginPath();
        context.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        context.fill();
        context.restore();
      }
    }

    let particles: Particle[] = [];

    function animateParticles(callback: () => void) {
      canvas.classList.remove('hidden');
      particles = [];
      let startTime = Date.now();
      const duration = 1200; 
      let callbackTriggered = false;

      function loop() {
        const elapsed = Date.now() - startTime;
        ctx!.clearRect(0, 0, canvas.width, canvas.height);

        if (elapsed < duration * 0.6) {
          const waveX = (elapsed / (duration * 0.6)) * canvas.width;
          for (let i = 0; i < 15; i++) {
            const startX = waveX - Math.random() * 80;
            if (startX > 0 && startX < canvas.width) {
              particles.push(new Particle(startX, canvas.height - Math.random() * 20));
            }
          }
        }

        particles.forEach((particle, index) => {
          particle.update();
          particle.draw(ctx!);
          if (particle.alpha <= 0 || particle.y < 0) {
            particles.splice(index, 1);
          }
        });

        if (elapsed >= duration * 0.4 && !callbackTriggered) {
          callbackTriggered = true;
          callback();
        }

        if (elapsed < duration || particles.length > 0) {
          requestAnimationFrame(loop);
        } else {
          canvas.classList.add('hidden');
          isAnimating = false;
        }
      }

      loop();
    }

    function transitionToSlide(nextIndex: number) {
      if (isAnimating || nextIndex === currentIndex) return;
      isAnimating = true;

      const currentSlide = slides[currentIndex];
      const nextSlide = slides[nextIndex];

      // FIX: CSS Transitions හරියාකාරව සිදුවීමට Opacity සහ Blur නිවැරදිව පාලනය කිරීම
      currentSlide.style.filter = 'blur(12px)';
      currentSlide.style.opacity = '0';
      currentSlide.style.zIndex = '5';

      nextSlide.style.filter = 'blur(0px)';
      nextSlide.style.opacity = '1';
      nextSlide.style.zIndex = '10';

      animateParticles(() => {
        dots.forEach((dot, i) => {
          if (i === nextIndex) {
            dot.classList.add('bg-primary', 'scale-125');
            dot.classList.remove('bg-white/50');
          } else {
            dot.classList.remove('bg-primary', 'scale-125');
            dot.classList.add('bg-white/50');
          }
        });

        setTimeout(() => {
          if (currentIndex !== nextIndex) {
            currentSlide.style.filter = 'blur(0px)';
            currentSlide.style.zIndex = '0';
          }
        }, 1200);

        currentIndex = nextIndex;
      });
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        transitionToSlide(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        if (isAnimating) return;
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        transitionToSlide(index);
        startInterval();
      });
    });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  // Astro Page Loads සඳහා 100% සුරක්ෂිතව ක්‍රියාත්මක කිරීම
  document.addEventListener('astro:page-load', initFineParticleSlider);
  // මුලින්ම ලෝඩ් වන විටද ට්‍රිගර් කිරීම
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initFineParticleSlider();
  } else {
    document.addEventListener('DOMContentLoaded', initFineParticleSlider);
  }
</script>
