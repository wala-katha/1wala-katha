    title: "තේශය ලබා - New Wal Katha",
    image: "https://blogger.googleusercontent.com/img/a/AVvXsEitbUL7Rq290BuqoH832SRuty1Uy2rgX0LTqs9oA5J8GLSk8lMWTYd7eL_8Bdg1BTyof9hMkkJr0BF-Rdyzmms0OdUUhliH-0WHHPja9Vn1rjNZ6zs2WFPVoyM6KSV337NOLJqnrEoiULB-48Pt7yRG6mNoL-gsydPNgjFgFki5NGFITvziTHNkRYzSl0M=s845",
    category: "Sinhala Stories",
