---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: any; 
  noindex?: boolean;
  canonical?: string;
}

// distructure frontmatters
const { title, meta_title, description, image, noindex, canonical } = Astro.props;

// --- 🧠 100% ACCURATE SMART SEO AUTO-FILL LOGIC ---
const calculatedTitle = plainify(
  meta_title && meta_title.trim() !== "" 
    ? meta_title 
    : title && title.trim() !== "" 
      ? `${title} - Wal Katha` 
      : config.site.title
);

const calculatedDescription = plainify(
  description && description.trim() !== "" 
    ? description 
    : config.metadata.meta_description
);

// Auto-fill Keywords for Search Engines
const siteKeywords = "Wal Katha, wala katha, wela katha, walkatha, සිංහල වැල කතා, sinhala wal katha, Wela kathaa, Sex Katha, Sex Stories, Wal Stories, Sinhala Sex, Sinhala Porn, Free Download, Sri Lanka";

// --- 🌐 CANONICAL URL FORMATTING ---
const siteUrl = config.site.base_url.endsWith("/") ? config.site.base_url.slice(0, -1) : config.site.base_url;
const cleanPath = Astro.url.pathname.startsWith("/") ? Astro.url.pathname : `/${Astro.url.pathname}`;
const currentCanonical = canonical ? canonical : `${siteUrl}${cleanPath}`;

// --- 🖼️ ABSOLUTE IMAGE URL RESOLVER (ROBUST METHOD) ---
let finalImageUrl = "";
let imageType = "image/jpeg"; // Default mime type

if (image) {
  if (typeof image === "string") {
    if (image.startsWith("http")) {
      finalImageUrl = image;
    } else {
      const imgPath = image.startsWith("/") ? image : `/${image}`;
      finalImageUrl = `${siteUrl}${imgPath}`;
    }
  } else if (typeof image === "object" && image !== null) {
    // Astro Content Image Object එකක Query Parameters අයින් කර පිරිසිදුම ලින්ක් එක ගැනීම
    let imgSrc = image.src || image.url || "";
    if (imgSrc) {
      imgSrc = imgSrc.split("?")[0]; // ?w=1200 වගේ කෑලි තියෙනවා නම් අයින් කරනවා
      if (imgSrc.startsWith("http")) {
        finalImageUrl = imgSrc;
      } else {
        const imgPath = imgSrc.startsWith("/") ? imgSrc : `/${imgSrc}`;
        finalImageUrl = `${siteUrl}${imgPath}`;
      }
    }
  }
}

// Fallback to default metadata image if empty
if (!finalImageUrl) {
  let defaultImg = config.metadata.meta_image || "";
  defaultImg = defaultImg.split("?")[0];
  if (defaultImg.startsWith("http")) {
    finalImageUrl = defaultImg;
  } else {
    const imgPath = defaultImg.startsWith("/") ? defaultImg : `/${defaultImg}`;
    finalImageUrl = `${siteUrl}${imgPath}`;
  }
}

// Dynamic image extension detection for WhatsApp
if (finalImageUrl.endsWith(".png")) imageType = "image/png";
else if (finalImageUrl.endsWith(".webp")) imageType = "image/webp";
else if (finalImageUrl.endsWith(".gif")) imageType = "image/gif";

const isArticle = Astro.url.pathname !== "/" && !Astro.url.pathname.startsWith("/categories") && !Astro.url.pathname.startsWith("/tags") && !Astro.url.pathname.startsWith("/search");
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="shortcut icon" href={config.site.favicon} />
    <meta name="theme-name" content="bookworm-light-astro" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#000" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

    <title>{calculatedTitle}</title>
    <meta name="description" content={calculatedDescription} />
    <meta name="keywords" content={siteKeywords} />
    <link rel="canonical" href={currentCanonical} />
    <meta name="author" content={config.metadata.meta_author} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:site_name" content="Wala Katha" />
    <meta property="og:url" content={currentCanonical} />
    <meta property="og:title" content={calculatedTitle} />
    <meta property="og:description" content={calculatedDescription} />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    
    <meta property="og:image" content={finalImageUrl} />
    <meta property="og:image:secure_url" content={finalImageUrl} />
    <meta property="og:image:type" content={imageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={currentCanonical} />
    <meta name="twitter:title" content={calculatedTitle} />
    <meta name="twitter:description" content={calculatedDescription} />
    <meta name="twitter:image" content={finalImageUrl} />

    <ClientRouter />
  </head>
  <body>
    <TwSizeIndicator />
    <Header />
    <main id="main-content" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
